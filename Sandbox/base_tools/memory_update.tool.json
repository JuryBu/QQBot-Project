{
  "name": "memory_update",
  "description": "更新已有记忆——支持替换内容、追加内容、修改标题/标签/置顶",
  "category": "memory",
  "timeout_ms": 5000,
  "parameters": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string",
        "description": "记忆ID"
      },
      "content": {
        "type": "string",
        "description": "替换全部内容"
      },
      "append": {
        "type": "string",
        "description": "追加到末尾"
      },
      "title": {
        "type": "string",
        "description": "新标题"
      },
      "tags": {
        "type": "string",
        "description": "新增标签JSON数组"
      },
      "category": {
        "type": "string",
        "description": "分类"
      },
      "search_summary": {
        "type": "string",
        "description": "搜索摘要"
      },
      "pinned": {
        "type": "string",
        "description": "是否置顶(true/false)"
      }
    },
    "required": [
      "id"
    ]
  },
  "builtin": true
}